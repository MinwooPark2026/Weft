# Weft 환경변수 템플릿 — 이 파일을 복사해 `.env`로 쓰고 키를 채운다.
# .env 는 개인 secret. git/공유 산출물에 넣지 말 것.

# ── 이미지 생성 (현재: OpenAI gpt-image-1) ──
OPENAI_API_KEY=
OPENAI_IMAGE_MODEL=gpt-image-1
IMAGE_CANDIDATES_N=3

# ── TTS: 2단 운용 (초안=무료 OpenAI / 최종=Typecast) ──
# 초안 단계: 길이·타이밍만 빠르게 (무료/저비용)
TTS_PROVIDER_DRAFT=openai
OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_TTS_VOICE=nova

# 최종 단계: 한국어 워드 타임스탬프 + SRT (나중에 키 넣으면 활성화)
TTS_PROVIDER_FINAL=typecast
TYPECAST_API_KEY=
TYPECAST_VOICE=
# 언어 (ISO 639-3): kor / eng / jpn …  (비우면 kor)
TYPECAST_LANGUAGE=kor
# 감정 프리셋 (ssfm-v30): normal / happy / sad / angry / whisper / toneup / tonedown
TYPECAST_EMOTION=normal

# (선택) 다른 엔진 대비 — 비워두면 미사용
ELEVENLABS_API_KEY=
