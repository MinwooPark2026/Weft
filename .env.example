# Weft 환경변수 템플릿 — 이 파일을 복사해 `.env`로 쓰고 키를 채운다.
# .env 는 개인 secret. git/공유 산출물에 넣지 말 것.

# ── 이미지 생성 ──
# openai | comfyui | stub — stub은 키 없이 로컬 테스트(플레이스홀더 이미지 생성)
IMAGE_PROVIDER=openai   # openai | comfyui | stub
OPENAI_API_KEY=
OPENAI_IMAGE_MODEL=gpt-image-1
# shot 당 후보 이미지 수 (코드 기본값 2)
IMAGE_CANDIDATES_N=2
# 품질: low | medium | high (기본 medium) — openai 전용, comfyui는 워크플로가 결정
IMAGE_QUALITY=medium
# 이미지 크기 (기본 1536x1024) — openai 전용, comfyui는 워크플로가 결정
IMAGE_SIZE=1536x1024

# ── ComfyUI 로컬 이미지 생성 (IMAGE_PROVIDER=comfyui 일 때) ──
# ComfyUI 서버 주소 (기본 http://127.0.0.1:8188)
COMFYUI_URL=http://127.0.0.1:8188
# ComfyUI에서 "Save (API Format)"으로 내보낸 워크플로 JSON 경로.
# JSON 안의 긍정 프롬프트(CLIPTextEncode 등) text 값을 __WEFT_PROMPT__ 로 바꿔두면
# shot 프롬프트가 안전하게(JSON 이스케이프) 치환된다.
# 선택: __WEFT_SEED__ 를 넣으면 후보마다 다른 시드로 치환 — 없으면 "seed" 키를 자동 치환.
COMFYUI_WORKFLOW=
# 생성 대기 한도(초). 기본 300
COMFYUI_TIMEOUT=300

# ── TTS (현재 지원: typecast / stub) ──
# typecast: 실제 Typecast API로 WAV 생성
# stub: API 없이 무음 WAV 플레이스홀더 생성
TTS_PROVIDER=typecast
TYPECAST_API_KEY=
TYPECAST_VOICE=
# 모델 (비우면 코드 기본값 ssfm-v30을 사용하지만, 명시해두는 것을 권장)
TYPECAST_MODEL=ssfm-v30
# 언어 (ISO 639-3): kor / eng / jpn …  (비우면 kor)
TYPECAST_LANGUAGE=kor
# 감정 프리셋 (ssfm-v30): normal / happy / sad / angry / whisper / toneup / tonedown
TYPECAST_EMOTION=normal
