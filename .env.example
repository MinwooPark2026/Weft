# Weft 환경변수 템플릿 — 이 파일을 복사해 `.env`로 쓰고 키를 채운다.
# .env 는 개인 secret. git/공유 산출물에 넣지 말 것.

# ── 이미지 생성 ──
# openai | gemini | comfyui | stub — stub은 키 없이 로컬 테스트(플레이스홀더 이미지 생성)
IMAGE_PROVIDER=openai   # openai | gemini | comfyui | stub
OPENAI_API_KEY=
# OpenAI 이미지 모델 (기본 gpt-image-2 = 현행 플래그십, 네이티브 16:9 — 예: 1920x1080)
# 더 싸게 쓰려면 gpt-image-1-mini — 단 ⚠ 종료 일정 주의:
#   gpt-image-1 → 2026-10-23 종료(이미 deprecated),
#   gpt-image-1-mini / gpt-image-1.5 / chatgpt-image-latest → 2026-12-01 종료.
#   이후에는 gpt-image-2 단일 체제.
OPENAI_IMAGE_MODEL=gpt-image-2
# Gemini (IMAGE_PROVIDER=gemini 일 때) — Google AI Studio(https://aistudio.google.com/apikey) 키.
# 유료 등급 전용(무료 등급 없음). GOOGLE_API_KEY 로 지정해도 인식된다.
GEMINI_API_KEY=
# 기본 gemini-3.1-flash-image (권장). 저가형: gemini-2.5-flash-image / 고품질·4K: gemini-3-pro-image
GEMINI_IMAGE_MODEL=gemini-3.1-flash-image
# Gemini 출력 크기: 512 | 1K | 2K | 4K (gemini-2.5-flash-image 는 1K 고정)
GEMINI_IMAGE_SIZE=1K
# shot 당 후보 이미지 수 (코드 기본값 2)
IMAGE_CANDIDATES_N=2
# 품질: low | medium | high (기본 medium) — openai 전용, gemini/comfyui는 모델·워크플로가 결정
IMAGE_QUALITY=medium
# 이미지 비율 (기본 16:9): 16:9 | 9:16 | 1:1 | 3:2
# 어떤 provider 가 어떤 크기를 반환하든 저장 시 이 비율로 정확히 센터 크롭된다.
# gemini 와 gpt-image-2 는 16:9 네이티브 생성, gpt-image-1 계열은 1536x1024 요청 후 1536x864 로 크롭.
IMAGE_ASPECT=16:9
# 이미지 크기 강제 (보통 비워 둠 — IMAGE_ASPECT 로 자동 결정) — openai 전용
#IMAGE_SIZE=
# 반복 캐릭터 시트: 프롬프트의 @char 마커가 이 이미지를 레퍼런스로 보낸다.
# 비우면 CHARACTER.png 를 자동 탐색 (CONTI.md 옆 또는 generated_project 안).
#CHARACTER_SHEET=

# ── ComfyUI 로컬 이미지 생성 (IMAGE_PROVIDER=comfyui 일 때) ──
# ComfyUI 서버 주소 (기본 http://127.0.0.1:8188)
COMFYUI_URL=http://127.0.0.1:8188
# ComfyUI에서 "Save (API Format)"으로 내보낸 워크플로 JSON 경로.
# JSON 안의 긍정 프롬프트(CLIPTextEncode 등) text 값을 __WEFT_PROMPT__ 로 바꿔두면
# shot 프롬프트가 안전하게(JSON 이스케이프) 치환된다.
# 선택: __WEFT_SEED__ 를 넣으면 후보마다 다른 시드로 치환 — 없으면 "seed" 키를 자동 치환.
# 해상도는 워크플로 JSON 책임 — IMAGE_ASPECT 와 같은 비율로 맞춰 두는 것을 권장
# (비율이 다르면 저장 시 센터 크롭된다).
COMFYUI_WORKFLOW=
# 생성 대기 한도(초). 기본 300
COMFYUI_TIMEOUT=300

# ── TTS (현재 지원: typecast / stub) ──
# typecast: 실제 Typecast API로 WAV 생성
# stub: API 없이 무음 WAV 플레이스홀더 생성
TTS_PROVIDER=typecast
TYPECAST_API_KEY=
TYPECAST_VOICE=
# 모델 (비우면 코드 기본값 ssfm-v30을 사용하지만, 명시해두는 것을 권장)
TYPECAST_MODEL=ssfm-v30
# 언어 (ISO 639-3): kor / eng / jpn …  (비우면 kor)
TYPECAST_LANGUAGE=kor
# 감정 프리셋 (ssfm-v30): normal / happy / sad / angry / whisper / toneup / tonedown
TYPECAST_EMOTION=normal
